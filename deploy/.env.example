# Comicseller deploy environment — copy to `.env` next to the stack and fill in.
# In Portainer you can instead paste these into the stack's
# "Environment variables" section. NEVER commit a real .env (it's gitignored).

# --- REQUIRED ---
# Generate a strong secret:  openssl rand -base64 48
JWT_SECRET=
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=change-me-min-8-chars

# --- RECOMMENDED ---
DB_PASSWORD=comicseller

# --- OPTIONAL ---
# Enables AI comic identification (leave blank to disable)
ANTHROPIC_API_KEY=
# Host port the app is reachable on
APP_PORT=4000
# Admin display name
ADMIN_NAME=Admin
# "1" to test identification without an API key
VISION_MOCK=0
# Base folder on the NAS for data (db + storage subfolders live here)
DATA_DIR=/volume1/docker/comicseller

# Postgres connection string.
# For local dev against the docker-compose db:
DATABASE_URL="postgresql://comicseller:comicseller@localhost:5432/comicseller?schema=public"

# Port the API server listens on
PORT=4000

# Environment: development | production
NODE_ENV=development

# --- Auth ---
# Strong random secret for signing login tokens (REQUIRED in production).
# Generate one: openssl rand -base64 48
JWT_SECRET=
JWT_EXPIRES_IN=7d
# First-admin seed: created automatically on first boot if no users exist.
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=Admin

# --- Deployment ---
# In production the backend serves the built frontend from one container.
# Set to 1 to also do that in dev. FRONTEND_DIR is relative to the compiled
# backend (dist). Build metadata is normally injected by CI.
SERVE_FRONTEND=0
# FRONTEND_DIR=../frontend/dist
# BUILD_SHA=
# BUILD_TIME=

# --- Phase 2: vision (comic identification & grade suggestion) ---
# Get a key at https://console.anthropic.com. Leave blank to disable identify.
ANTHROPIC_API_KEY=
# Model used for identification
VISION_MODEL=claude-sonnet-4-5
# Where photos are stored on disk (local object storage; swap for S3 later)
STORAGE_DIR=./storage
# Public base path photos are served under
STORAGE_PUBLIC_PATH=/photos
# Set to "1" to return mock identification when no ANTHROPIC_API_KEY is set
# (lets you exercise the flow without a key). Never enable in production.
VISION_MOCK=0

# --- eBay API (Phase 5) — see docs/ebay-developer-setup.md ---
# EBAY_CLIENT_ID=
# EBAY_CLIENT_SECRET=
# EBAY_REDIRECT_URI=
# EBAY_ENV=sandbox
